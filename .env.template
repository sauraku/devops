# DevOps Control Plane environment template.
# Generate unique values; never commit populated secrets.
DEPLOY_CONTROL_TOKEN=change_me
COOKIE_SECRET=change_me
ENCRYPTION_KEY=change_me

DEPLOY_CONTROL_HOST=127.0.0.1
DEPLOY_CONTROL_PORT=8787
# External TLS origin used by bootstrap for end-to-end health and login checks.
# Required with COOKIE_SECURE=true; use an origin only, with no path or query.
DEPLOY_CONTROL_PUBLIC_URL=https://devops.example.com
BASE_DIR=/opt/devops-control
DEFAULT_PROJECT_ID=
DEPLOY_CONTROL_ALLOWED_REPO_PREFIXES=https://github.com/
# Comma-separated IPs/CIDRs of the immediate TLS reverse proxy and any trusted
# proxies before it. Leave empty when connecting directly. Forwarding headers
# from all other peers are ignored.
TRUSTED_PROXY_CIDRS=

# Optional GitHub PAT used to register repository-scoped runners.
GITHUB_TOKEN=
RUNNER_IMAGE=ghcr.io/sauraku/devops-runner:main
RUNNER_NETWORK=devops-control-runners
# Native controller default. Container bootstrap sets this to http://devops-control:8787.
RUNNER_CONTROL_URL=http://host.docker.internal:8787

BACKUP_SCHEDULE=06:00
BACKUP_RETENTION=30
ENABLE_RESTORE=false

# The SSH terminal is off by default. If enabled, pin host keys explicitly.
ENABLE_TERMINAL=false
SSH_KNOWN_HOSTS=/home/devops/.ssh/known_hosts
SSH_HOST=127.0.0.1
# Set true in production. Browser authentication then refuses to render or
# accept the token form when the effective transport is not HTTPS.
COOKIE_SECURE=false
